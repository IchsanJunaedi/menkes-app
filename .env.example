# ─────────────────────────────────────────────────────────────────────────────
# SehatKu EHR — Environment Variables Example
# Copy this file to .env and fill in your values
# NEVER commit .env to git — only .env.example
# ─────────────────────────────────────────────────────────────────────────────

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=ehr_db
POSTGRES_USER=ehr_user
POSTGRES_PASSWORD=change_me_in_production
POSTGRES_PORT=5432

# Prisma connection string (used by NestJS & Prisma CLI)
DATABASE_URL=postgresql://ehr_user:change_me_in_production@localhost:5432/ehr_db
DATABASE_POOL_MIN=2
DATABASE_POOL_MAX=10

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_PASSWORD=change_me_in_production
REDIS_URL=redis://:change_me_in_production@localhost:6379

# ── MinIO (S3-compatible Storage) ─────────────────────────────────────────────
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ACCESS_KEY=minio_admin
MINIO_SECRET_KEY=change_me_in_production
MINIO_ENDPOINT=localhost
MINIO_BUCKET_DOCUMENTS=ehr-documents
MINIO_USE_SSL=false

# ── Keycloak (Identity Provider) ──────────────────────────────────────────────
KEYCLOAK_PORT=8080
KEYCLOAK_ADMIN=admin
KEYCLOAK_ADMIN_PASSWORD=change_me_in_production

# Used by NestJS to validate JWT tokens
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=ehr-system
KEYCLOAK_CLIENT_ID=ehr-api
KEYCLOAK_CLIENT_SECRET=<set-after-realm-creation-in-phase-1.2>

# Frontend clients
NEXT_PUBLIC_KEYCLOAK_URL=http://localhost:8080
NEXT_PUBLIC_KEYCLOAK_REALM=ehr-system
NEXT_PUBLIC_KEYCLOAK_CLIENT_ID=ehr-web

# ── HashiCorp Vault ───────────────────────────────────────────────────────────
VAULT_PORT=8200
VAULT_ADDR=http://localhost:8200
VAULT_DEV_ROOT_TOKEN=dev-root-token
# WARNING: dev-root-token is for local dev only. Use proper auth in production.

# ── HAPI FHIR Server ─────────────────────────────────────────────────────────
HAPI_FHIR_PORT=8090
HAPI_FHIR_URL=http://localhost:8090/fhir

# ── Prometheus ────────────────────────────────────────────────────────────────
PROMETHEUS_PORT=9090

# ── Loki ─────────────────────────────────────────────────────────────────────
LOKI_PORT=3100

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_PORT=3200
GRAFANA_USER=admin
GRAFANA_PASSWORD=change_me_in_production

# ── Application (NestJS API) ──────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# JWT issuer matches Keycloak realm URL
JWT_ISSUER=http://localhost:8080/realms/ehr-system

# CORS — comma-separated allowed origins
CORS_ORIGINS=http://localhost:3001,http://localhost:3002

# ── Application (Next.js Web) ─────────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
