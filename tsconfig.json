{
    "compilerOptions": {
        "target": "ES2022",
        "module": "commonjs",
        "moduleResolution": "node",
        "lib": [
            "ES2022"
        ],
        "strict": true,
        "esModuleInterop": true,
        "skipLibCheck": true,
        "forceConsistentCasingInFileNames": true,
        "resolveJsonModule": true,
        "declaration": true,
        "declarationMap": true,
        "sourceMap": true,
        "baseUrl": ".",
        "paths": {
            "@sehatku/shared": [
                "packages/shared/src"
            ],
            "@sehatku/fhir": [
                "packages/fhir/src"
            ],
            "@sehatku/ui": [
                "packages/ui/src"
            ]
        }
    },
    "exclude": [
        "node_modules",
        "dist",
        ".next",
        "build",
        "coverage"
    ]
}